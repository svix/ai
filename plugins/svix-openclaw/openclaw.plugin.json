{
  "id": "svix-openclaw",
  "activation": {
    "onStartup": true
  },
  "name": "Svix OpenClaw",
  "description": "Receives OpenClaw webhook events by polling Svix Polling Endpoints instead of exposing an inbound HTTP server: applies TaskFlow actions and/or forwards messages to the gateway /hooks/wake and /hooks/agent automation endpoints.",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "$defs": {
      "secretRef": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "source": {
            "type": "string",
            "enum": ["env", "file", "exec"]
          },
          "provider": { "type": "string" },
          "id": { "type": "string" }
        },
        "required": ["source", "provider", "id"]
      },
      "secretInput": {
        "anyOf": [{ "type": "string", "minLength": 1 }, { "$ref": "#/$defs/secretRef" }]
      },
      "hookEndpoint": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "token": { "$ref": "#/$defs/secretInput" },
          "subscribe": { "type": "boolean" },
          "filterTypes": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "minItems": 1
          },
          "channels": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "minItems": 1
          },
          "consumerId": { "type": "string", "minLength": 1 },
          "startingPosition": { "type": "string", "enum": ["earliest", "latest"] },
          "leaseDurationMs": { "type": "integer", "minimum": 1 },
          "pollIntervalMs": { "type": "integer", "minimum": 1 },
          "limit": { "type": "integer", "minimum": 1, "maximum": 500 },
          "payloadField": { "type": "string" }
        },
        "required": ["token"]
      },
      "route": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean" },
          "token": { "$ref": "#/$defs/secretInput" },
          "sessionKey": { "type": "string", "minLength": 1 },
          "controllerId": { "type": "string", "minLength": 1 },
          "subscribe": { "type": "boolean" },
          "filterTypes": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "minItems": 1
          },
          "channels": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "minItems": 1
          },
          "consumerId": { "type": "string", "minLength": 1 },
          "startingPosition": { "type": "string", "enum": ["earliest", "latest"] },
          "leaseDurationMs": { "type": "integer", "minimum": 1 },
          "pollIntervalMs": { "type": "integer", "minimum": 1 },
          "limit": { "type": "integer", "minimum": 1, "maximum": 500 },
          "payloadField": { "type": "string" },
          "description": { "type": "string" }
        },
        "required": ["token", "sessionKey"]
      }
    },
    "properties": {
      "routes": {
        "type": "object",
        "additionalProperties": {
          "$ref": "#/$defs/route"
        }
      },
      "wake": { "$ref": "#/$defs/hookEndpoint" },
      "agent": { "$ref": "#/$defs/hookEndpoint" }
    }
  }
}
